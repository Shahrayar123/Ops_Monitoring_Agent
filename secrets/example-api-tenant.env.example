# Per-customer secrets file — TEMPLATE.
#
# For a real customer: copy this file to secrets/<tenant_id>.env (matching the
# tenant_id in their config/tenants/<tenant_id>.yaml) and fill in the values.
# Real *.env files in this folder are gitignored; only this .example is committed.
#
# The variable NAMES must match what the customer's YAML references under
# credentials.username_env / password_env and ssh.username_env / key_path_env.

EXAMPLE_TENANT_CM_USERNAME=
EXAMPLE_TENANT_CM_PASSWORD=
EXAMPLE_TENANT_SSH_USERNAME=
EXAMPLE_TENANT_SSH_KEY_PATH=
