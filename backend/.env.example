# Copy the values you need into the repo-root .env (the backend reads that).

# --- database ---
# Production (PostgreSQL):
#   DATABASE_URL=postgresql+psycopg://ops:secret@localhost:5432/ops_monitoring
# Dev fallback (used automatically when DATABASE_URL is unset): SQLite at backend/ops.db

# --- auth / secrets ---
# Generated into .env automatically on first run if missing. Set explicitly in production.
# SECRET_KEY=<jwt signing key>
# ENCRYPTION_KEY=<fernet key for stored API keys / CM passwords>
# ACCESS_TOKEN_MINUTES=30
# REFRESH_TOKEN_DAYS=7

# --- first-run admin (seed) ---
# ADMIN_EMAIL=admin@blutechconsulting.com
# ADMIN_PASSWORD=ChangeMe!123

# --- CORS (React dev server) ---
# CORS_ORIGINS=["http://localhost:5173"]
