# Copy this file to `.env` and fill in real values. `.env` itself is gitignored
# — never commit real credentials. Loaded at process startup and re-read by the
# dashboard on every page refresh.

# --- Data source selection ---
# Normally you don't set anything here: each customer's YAML profile
# (config/tenants/<customer>.yaml) decides its own source via data_source.type —
#   type: json  -> the JSON files the customer provided (demo stage)
#   type: api   -> their live Cloudera cluster (after demo approval)
# Moving a customer from demo to production = changing that one line in their
# YAML and adding their credentials below. No code changes.
#
# USE_JSON is an optional OVERRIDE for development/testing that forces every
# tenant in this process to one source. Leave it commented out in production.
#   USE_JSON=true   -> force JSON files for all tenants
#   USE_JSON=false  -> force the live API for all tenants
# USE_JSON=true

# --- AI model (shared infrastructure, served locally by Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_API_KEY=ollama

# --- Where the dashboard finds the API backend ---
# The Streamlit dashboard is a thin client that calls the FastAPI backend.
# Default assumes the API runs on the same machine, port 8000.
API_BASE_URL=http://127.0.0.1:8000

# --- Per-customer credentials do NOT go in this file ---
# Each customer's credentials live in their own file: secrets/<tenant_id>.env
# (see secrets/example-api-tenant.env.example). That file is loaded
# automatically when the customer's data source is built. This global .env is
# for shared, non-customer settings only.
